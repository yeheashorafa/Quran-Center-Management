generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  DISABLED
  LOCKED

  @@map("user_status")
}

enum ProgramType {
  BASE
  SEASONAL

  @@map("program_type")
}

enum ProgramStatus {
  ACTIVE
  INACTIVE
  ARCHIVED

  @@map("program_status")
}

enum HalaqaStatus {
  ACTIVE
  INACTIVE
  ARCHIVED

  @@map("halaqa_status")
}

enum Weekday {
  SATURDAY
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY

  @@map("weekday")
}

enum StaffAssignmentRole {
  PRIMARY_TEACHER
  ASSISTANT_TEACHER

  @@map("staff_assignment_role")
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  TRANSFERRED
  WITHDRAWN
  INACTIVE

  @@map("enrollment_status")
}

enum MemorizationSessionStatus {
  DRAFT
  COMPLETED
  LOCKED

  @@map("memorization_session_status")
}

enum AttendanceStatus {
  PENDING
  PRESENT
  ABSENT
  EXCUSED
  NOT_HEARD

  @@map("attendance_status")
}

enum ActivityType {
  MEMORIZATION
  REVIEW
  RECITATION

  @@map("activity_type")
}

enum ExamType {
  INDIVIDUAL
  COLLECTIVE
  CUSTOM

  @@map("exam_type")
}

enum ExamStatus {
  ACTIVE
  VOIDED

  @@map("exam_status")
}

enum ExamScopeType {
  JUZ
  SURAH
  AYAH_RANGE
  PAGE_RANGE
  CUSTOM

  @@map("exam_scope_type")
}

model User {
  id                 String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username           String     @db.VarChar(80)
  normalizedUsername String     @unique @map("normalized_username") @db.VarChar(80)
  displayName        String     @map("display_name") @db.VarChar(160)
  passwordHash       String     @map("password_hash") @db.Text
  status             UserStatus @default(ACTIVE)
  failedLoginCount   Int        @default(0) @map("failed_login_count")
  lockedUntil        DateTime?  @map("locked_until") @db.Timestamptz(3)
  lastLoginAt        DateTime?  @map("last_login_at") @db.Timestamptz(3)
  passwordChangedAt  DateTime?  @map("password_changed_at") @db.Timestamptz(3)
  createdAt          DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt          DateTime?  @map("deleted_at") @db.Timestamptz(3)

  roles                 UserRole[]
  authSessions          AuthSession[]
  staffAssignments      HalaqaStaffAssignment[]
  createdStudents       Student[]               @relation("StudentCreatedBy")
  createdEnrollments    StudentEnrollment[]     @relation("EnrollmentCreatedBy")
  transferredStudents   StudentTransfer[]       @relation("TransferPerformedBy")
  createdSessions       MemorizationSession[]   @relation("SessionCreatedBy")
  completedSessions     MemorizationSession[]   @relation("SessionCompletedBy")
  examinedOfficialExams OfficialExam[]          @relation("OfficialExamExaminer")
  createdOfficialExams  OfficialExam[]          @relation("OfficialExamCreatedBy")
  auditLogs             AuditLog[]

  @@index([status, deletedAt])
  @@map("users")
}

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique @db.VarChar(80)
  nameAr      String   @map("name_ar") @db.VarChar(120)
  description String?  @db.Text
  isSystem    Boolean  @default(true) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  users        UserRole[]
  permissions  RolePermission[]
  authSessions AuthSession[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique @db.VarChar(120)
  nameAr      String   @map("name_ar") @db.VarChar(160)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  roles RolePermission[]

  @@map("permissions")
}

model UserRole {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)
  role Role @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  grantedAt    DateTime @default(now()) @map("granted_at") @db.Timestamptz(3)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model AuthSession {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  activeRoleId   String?   @map("active_role_id") @db.Uuid
  tokenHash      String    @unique @map("token_hash") @db.VarChar(128)
  rememberDevice Boolean   @default(false) @map("remember_device")
  deviceLabel    String?   @map("device_label") @db.VarChar(160)
  userAgent      String?   @map("user_agent") @db.Text
  ipAddress      String?   @map("ip_address") @db.VarChar(64)
  lastSeenAt     DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz(3)
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt      DateTime? @map("revoked_at") @db.Timestamptz(3)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeRole Role? @relation(fields: [activeRoleId], references: [id], onDelete: Restrict)

  @@index([userId, expiresAt])
  @@index([activeRoleId])
  @@index([expiresAt, revokedAt])
  @@map("auth_sessions")
}

model Program {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code       String        @unique @db.VarChar(60)
  nameAr     String        @map("name_ar") @db.VarChar(120)
  type       ProgramType
  status     ProgramStatus @default(ACTIVE)
  startsOn   DateTime?     @map("starts_on") @db.Date
  endsOn     DateTime?     @map("ends_on") @db.Date
  archivedAt DateTime?     @map("archived_at") @db.Timestamptz(3)
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt  DateTime?     @map("deleted_at") @db.Timestamptz(3)

  halaqat     Halaqa[]
  enrollments StudentEnrollment[]

  @@index([type, status, deletedAt])
  @@map("programs")
}

model Stage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String   @unique @db.VarChar(60)
  nameAr    String   @map("name_ar") @db.VarChar(120)
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  defaultSchedules StageDefaultSchedule[]
  halaqat          Halaqa[]

  @@index([isActive, sortOrder])
  @@map("stages")
}

model StageDefaultSchedule {
  id      String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stageId String  @map("stage_id") @db.Uuid
  weekday Weekday

  stage Stage @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@unique([stageId, weekday])
  @@map("stage_default_schedules")
}

model Halaqa {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String       @unique @db.VarChar(80)
  nameAr    String       @map("name_ar") @db.VarChar(160)
  programId String       @map("program_id") @db.Uuid
  stageId   String?      @map("stage_id") @db.Uuid
  status    HalaqaStatus @default(ACTIVE)
  notes     String?      @db.Text
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime?    @map("deleted_at") @db.Timestamptz(3)

  program          Program                 @relation(fields: [programId], references: [id], onDelete: Restrict)
  stage            Stage?                  @relation(fields: [stageId], references: [id], onDelete: Restrict)
  schedules        HalaqaSchedule[]
  staffAssignments HalaqaStaffAssignment[]
  enrollments      StudentEnrollment[]
  sessions         MemorizationSession[]

  @@index([programId, status, deletedAt])
  @@index([stageId, status, deletedAt])
  @@map("halaqat")
}

model HalaqaSchedule {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  halaqaId      String    @map("halaqa_id") @db.Uuid
  weekday       Weekday
  effectiveFrom DateTime  @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  halaqa Halaqa @relation(fields: [halaqaId], references: [id], onDelete: Cascade)

  @@unique([halaqaId, weekday, effectiveFrom])
  @@unique([halaqaId, weekday], map: "halaqa_schedules_one_open_period_key", where: raw("\"effective_to\" IS NULL"))
  @@index([halaqaId, effectiveFrom, effectiveTo])
  @@map("halaqa_schedules")
}

model HalaqaStaffAssignment {
  id        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  halaqaId  String              @map("halaqa_id") @db.Uuid
  userId    String              @map("user_id") @db.Uuid
  role      StaffAssignmentRole @default(PRIMARY_TEACHER)
  startsOn  DateTime            @map("starts_on") @db.Date
  endsOn    DateTime?           @map("ends_on") @db.Date
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime?           @map("deleted_at") @db.Timestamptz(3)

  halaqa   Halaqa                @relation(fields: [halaqaId], references: [id], onDelete: Restrict)
  user     User                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  sessions MemorizationSession[]

  @@unique([halaqaId, userId, startsOn])
  @@unique([halaqaId], map: "halaqa_one_active_primary_teacher_key", where: raw("\"role\" = 'PRIMARY_TEACHER' AND \"ends_on\" IS NULL AND \"deleted_at\" IS NULL"))
  @@index([userId, startsOn, endsOn])
  @@index([halaqaId, role, startsOn, endsOn])
  @@map("halaqa_staff_assignments")
}

model Student {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fullName              String    @map("full_name") @db.VarChar(200)
  normalizedFullName    String    @map("normalized_full_name") @db.VarChar(200)
  displayName           String    @map("display_name") @db.VarChar(160)
  parentPhone           String?   @map("parent_phone") @db.VarChar(40)
  gradeLevel            String?   @map("grade_level") @db.VarChar(80)
  memorizationStartedOn DateTime? @map("memorization_started_on") @db.Date
  notes                 String?   @db.Text
  isActive              Boolean   @default(true) @map("is_active")
  createdByUserId       String?   @map("created_by_user_id") @db.Uuid
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt             DateTime? @map("deleted_at") @db.Timestamptz(3)

  createdByUser User?               @relation("StudentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  enrollments   StudentEnrollment[]
  transfers     StudentTransfer[]
  sessionItems  SessionRecordItem[]
  officialExams OfficialExam[]

  @@index([normalizedFullName])
  @@index([isActive, deletedAt])
  @@map("students")
}

model StudentEnrollment {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId       String           @map("student_id") @db.Uuid
  programId       String           @map("program_id") @db.Uuid
  halaqaId        String           @map("halaqa_id") @db.Uuid
  status          EnrollmentStatus @default(ACTIVE)
  startedOn       DateTime         @map("started_on") @db.Date
  endedOn         DateTime?        @map("ended_on") @db.Date
  endReason       String?          @map("end_reason") @db.VarChar(240)
  createdByUserId String?          @map("created_by_user_id") @db.Uuid
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt       DateTime?        @map("deleted_at") @db.Timestamptz(3)

  student       Student @relation(fields: [studentId], references: [id], onDelete: Restrict)
  program       Program @relation(fields: [programId], references: [id], onDelete: Restrict)
  halaqa        Halaqa  @relation(fields: [halaqaId], references: [id], onDelete: Restrict)
  createdByUser User?   @relation("EnrollmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  transferFrom  StudentTransfer?    @relation("TransferFromEnrollment")
  transferTo    StudentTransfer?    @relation("TransferToEnrollment")
  sessionItems  SessionRecordItem[]
  officialExams OfficialExam[]

  @@unique([studentId, halaqaId, startedOn])
  @@unique([studentId, programId], map: "student_one_active_enrollment_per_program_key", where: raw("\"status\" = 'ACTIVE' AND \"ended_on\" IS NULL AND \"deleted_at\" IS NULL"))
  @@index([studentId, status, startedOn, endedOn])
  @@index([programId, status, endedOn])
  @@index([halaqaId, status, endedOn])
  @@map("student_enrollments")
}

model StudentTransfer {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId           String   @map("student_id") @db.Uuid
  fromEnrollmentId    String   @unique @map("from_enrollment_id") @db.Uuid
  toEnrollmentId      String   @unique @map("to_enrollment_id") @db.Uuid
  transferredByUserId String?  @map("transferred_by_user_id") @db.Uuid
  transferDate        DateTime @map("transfer_date") @db.Date
  note                String?  @db.Text
  idempotencyKey      String?  @unique @map("idempotency_key") @db.VarChar(120)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  student           Student           @relation(fields: [studentId], references: [id], onDelete: Restrict)
  fromEnrollment    StudentEnrollment @relation("TransferFromEnrollment", fields: [fromEnrollmentId], references: [id], onDelete: Restrict)
  toEnrollment      StudentEnrollment @relation("TransferToEnrollment", fields: [toEnrollmentId], references: [id], onDelete: Restrict)
  transferredByUser User?             @relation("TransferPerformedBy", fields: [transferredByUserId], references: [id], onDelete: SetNull)

  @@index([studentId, transferDate])
  @@index([transferDate])
  @@map("student_transfers")
}

model MemorizationSession {
  id                  String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  halaqaId            String                    @map("halaqa_id") @db.Uuid
  teacherAssignmentId String?                   @map("teacher_assignment_id") @db.Uuid
  sessionDate         DateTime                  @map("session_date") @db.Date
  status              MemorizationSessionStatus @default(DRAFT)
  notes               String?                   @db.Text
  version             Int                       @default(1)
  idempotencyKey      String?                   @unique @map("idempotency_key") @db.VarChar(120)
  createdByUserId     String?                   @map("created_by_user_id") @db.Uuid
  completedByUserId   String?                   @map("completed_by_user_id") @db.Uuid
  completedAt         DateTime?                 @map("completed_at") @db.Timestamptz(3)
  createdAt           DateTime                  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt           DateTime?                 @map("deleted_at") @db.Timestamptz(3)

  halaqa            Halaqa                 @relation(fields: [halaqaId], references: [id], onDelete: Restrict)
  teacherAssignment HalaqaStaffAssignment? @relation(fields: [teacherAssignmentId], references: [id], onDelete: SetNull)
  createdByUser     User?                  @relation("SessionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  completedByUser   User?                  @relation("SessionCompletedBy", fields: [completedByUserId], references: [id], onDelete: SetNull)
  items             SessionRecordItem[]

  @@unique([halaqaId, sessionDate])
  @@index([sessionDate, status])
  @@index([teacherAssignmentId, sessionDate])
  @@map("memorization_sessions")
}

model SessionRecordItem {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId    String           @map("session_id") @db.Uuid
  studentId    String           @map("student_id") @db.Uuid
  enrollmentId String?          @map("enrollment_id") @db.Uuid
  attendance   AttendanceStatus @default(PENDING)
  notes        String?          @db.Text
  version      Int              @default(1)
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  session    MemorizationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student    Student             @relation(fields: [studentId], references: [id], onDelete: Restrict)
  enrollment StudentEnrollment?  @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  activities SessionActivity[]

  @@unique([sessionId, studentId])
  @@index([studentId, sessionId])
  @@index([attendance, sessionId])
  @@map("session_record_items")
}

model SessionActivity {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  itemId    String       @map("item_id") @db.Uuid
  type      ActivityType
  orderNo   Int          @default(1) @map("order_no")
  surahName String?      @map("surah_name") @db.VarChar(120)
  fromAyah  Int?         @map("from_ayah")
  toAyah    Int?         @map("to_ayah")
  fromPage  Int?         @map("from_page")
  toPage    Int?         @map("to_page")
  pageCount Decimal      @default(0) @map("page_count") @db.Decimal(8, 2)
  details   Json?
  notes     String?      @db.Text
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)

  item SessionRecordItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, type, orderNo])
  @@index([type, itemId])
  @@map("session_activities")
}

model OfficialExam {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId       String     @map("student_id") @db.Uuid
  enrollmentId    String?    @map("enrollment_id") @db.Uuid
  examinerUserId  String     @map("examiner_user_id") @db.Uuid
  createdByUserId String?    @map("created_by_user_id") @db.Uuid
  examDate        DateTime   @map("exam_date") @db.Date
  examType        ExamType   @map("exam_type")
  status          ExamStatus @default(ACTIVE)
  score           Decimal?   @db.Decimal(5, 2)
  resultLabel     String?    @map("result_label") @db.VarChar(80)
  notes           String?    @db.Text
  version         Int        @default(1)
  idempotencyKey  String?    @unique @map("idempotency_key") @db.VarChar(120)
  voidedAt        DateTime?  @map("voided_at") @db.Timestamptz(3)
  voidReason      String?    @map("void_reason") @db.Text
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)

  student       Student             @relation(fields: [studentId], references: [id], onDelete: Restrict)
  enrollment    StudentEnrollment?  @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  examinerUser  User                @relation("OfficialExamExaminer", fields: [examinerUserId], references: [id], onDelete: Restrict)
  createdByUser User?               @relation("OfficialExamCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  scopes        OfficialExamScope[]

  @@index([studentId, examDate])
  @@index([examinerUserId, examDate])
  @@index([examDate, status])
  @@map("official_exams")
}

model OfficialExamScope {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  examId     String        @map("exam_id") @db.Uuid
  orderNo    Int           @default(1) @map("order_no")
  type       ExamScopeType
  juzFrom    Int?          @map("juz_from")
  juzTo      Int?          @map("juz_to")
  surahName  String?       @map("surah_name") @db.VarChar(120)
  ayahFrom   Int?          @map("ayah_from")
  ayahTo     Int?          @map("ayah_to")
  pageFrom   Int?          @map("page_from")
  pageTo     Int?          @map("page_to")
  customText String?       @map("custom_text") @db.Text
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)

  exam OfficialExam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([examId, orderNo])
  @@index([type, examId])
  @@map("official_exam_scopes")
}

model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String   @db.VarChar(120)
  entityType  String   @map("entity_type") @db.VarChar(100)
  entityId    String?  @map("entity_id") @db.Uuid
  oldValues   Json?    @map("old_values")
  newValues   Json?    @map("new_values")
  metadata    Json?
  requestId   String?  @map("request_id") @db.Uuid
  deviceId    String?  @map("device_id") @db.VarChar(120)
  ipAddress   String?  @map("ip_address") @db.VarChar(64)
  userAgent   String?  @map("user_agent") @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  actorUser User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

model LegacyMigrationRun {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceSystem      String    @map("source_system") @db.VarChar(100)
  sourceFingerprint String    @map("source_fingerprint") @db.VarChar(64)
  status            String    @db.VarChar(40)
  dryRun            Boolean   @default(false) @map("dry_run")
  inputManifest     Json?     @map("input_manifest")
  summary           Json?
  errorMessage      String?   @map("error_message") @db.Text
  startedAt         DateTime  @default(now()) @map("started_at") @db.Timestamptz(3)
  completedAt       DateTime? @map("completed_at") @db.Timestamptz(3)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  idMaps LegacyIdMap[]

  @@index([sourceSystem, sourceFingerprint, status])
  @@index([startedAt])
  @@map("legacy_migration_runs")
}

model LegacyIdMap {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  runId        String?  @map("run_id") @db.Uuid
  sourceSystem String   @map("source_system") @db.VarChar(100)
  entityType   String   @map("entity_type") @db.VarChar(80)
  legacyId     String   @map("legacy_id") @db.VarChar(300)
  newId        String   @map("new_id") @db.Uuid
  canonicalKey String?  @map("canonical_key") @db.Text
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  run LegacyMigrationRun? @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@unique([sourceSystem, entityType, legacyId])
  @@index([entityType, newId])
  @@index([runId])
  @@map("legacy_id_maps")
}
