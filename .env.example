# Database Connection (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/quran_center_db?schema=public"

# Session Security (32+ chars random string)
SESSION_SECRET="your-32-character-long-secret-key-change-this-in-production"

# Application Settings
NODE_ENV="production"
PORT=3000

# Center Customization
NEXT_PUBLIC_CENTER_NAME="مركز سيد الشهداء حمزة لتلاوة القرآن وتحفيظه"

# PWA Control (set to "true" to enable Service Worker)
NEXT_PUBLIC_ENABLE_PWA="false"

# Application URL
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"


